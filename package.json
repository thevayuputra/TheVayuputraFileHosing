{
  "name": "Simple File Hosting",
  "version": "0.1.0",
  "homepage": "https://thevayuputra.github.io/TheVayuputraFileHosing/",
  "private": true,
  "scripts": {
    "serve": "vite preview --port 8080",
    "build": "npm run gen-tree && vite build && node scripts/flatten.js",
    "gen-tree": "node scripts/generateTree.js",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore --fix src",
    "dev": "npm run gen-tree && vite"
  },
  "dependencies": {
    "vue": "^3.3.6",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "vite": "^4.5.0",
    "@vitejs/plugin-vue": "^4.4.0"
  }
}
